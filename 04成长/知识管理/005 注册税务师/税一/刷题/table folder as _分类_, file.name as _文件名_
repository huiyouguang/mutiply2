table folder as "分类", file.name as "文件名"
from "mutiply2"
where contains(file.folder, "mutiply2/")
group by choice(
    regexmatch("^mutiply2/000 life os", file.folder), "000 life os",
    regexmatch("^mutiply2/002 司法考试", file.folder), "002 司法考试",
    regexmatch("^mutiply2/003 中级", file.folder), "003 中级",
    regexmatch("^mutiply2/004 注会", file.folder), "004 注会",
    regexmatch("^mutiply2/005 注册税务师", file.folder), "005 注册税务师",
    regexmatch("^mutiply2/模板", file.folder), "模板",
    "其他"
) as folder